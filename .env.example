COMPOSE_PROJECT_NAME=bm-odoo-suite

ODOO_IMAGE=odoo:18.0
ODOO_PORT=8069

POSTGRES_IMAGE=postgres:15
POSTGRES_DB=postgres
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me_postgres_password

# Optional default used by scripts/backup.sh and scripts/restore.sh.
# Use this same name when creating the Odoo database in the web UI.
ODOO_DB=odoo
